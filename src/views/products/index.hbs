<section>
  <header class="section-header">
    <h1>Monitored Products</h1>
    <div class="section-actions">
      <form action="/products/refresh" method="POST" class="inline-form">
        <button type="submit" class="btn btn-secondary">Refresh prices</button>
      </form>
      <a class="btn" href="/products/create">Add Product</a>
    </div>
  </header>

  {{#if products.length}}
    <div class="product-grid">
      {{#each products}}
        {{!-- Provide a CSS-friendly status class --}}
        {{#with this}}
          {{> productCard statusClass=(lowercase status) }}
        {{/with}}
      {{/each}}
    </div>

    <div class="pagination">
      <span class="pagination-info">
        Page {{currentPage}} of {{totalPages}}
      </span>
      <div class="pagination-links">
        {{#if hasPrev}}
          <a href="/products?page={{prevPage}}" class="btn btn-secondary btn-sm">Previous</a>
        {{/if}}
        {{#if hasNext}}
          <a href="/products?page={{nextPage}}" class="btn btn-secondary btn-sm">Next</a>
        {{/if}}
      </div>
    </div>
  {{else}}
    <p>No products are being monitored yet.</p>
    <p>
      <a class="btn" href="/products/create">Add your first product</a>
    </p>
  {{/if}}
</section>

